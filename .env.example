# ═══════════════════════════════════════════════════════════════════════════════
# ComplianceLoop — Environment Variables
# Copy to .env and fill in all values before running.
# NEVER commit .env to version control.
# All secrets marked [SECRET] must be generated fresh — see scripts/generate_secrets.sh
# ═══════════════════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development                          # development | staging | production
APP_NAME=ComplianceLoop
APP_VERSION=1.0.0
DEBUG=false                                  # Set true only in development
LOG_LEVEL=INFO                               # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change-me-in-production           # [SECRET] General app secret key (32+ chars)

# ── API Server ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4                                # Number of Uvicorn worker processes
API_RELOAD=false                             # Hot reload — true only in dev
API_DOCS_ENABLED=true                        # Disable /docs in production if desired
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
ALLOWED_HOSTS=localhost,127.0.0.1

# ── PostgreSQL (Production) ──────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=complianceloop
POSTGRES_USER=complianceloop
POSTGRES_PASSWORD=change-me                  # [SECRET]
POSTGRES_DSN=postgresql+asyncpg://complianceloop:change-me@localhost:5432/complianceloop
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10
POSTGRES_POOL_TIMEOUT=30
POSTGRES_ECHO=false                          # Set true to log all SQL queries (dev only)

# ── PostgreSQL (Demo — separate instance) ────────────────────────────────────
DEMO_POSTGRES_HOST=localhost
DEMO_POSTGRES_PORT=5433                      # Different port from prod
DEMO_POSTGRES_DB=complianceloop_demo
DEMO_POSTGRES_USER=complianceloop_demo
DEMO_POSTGRES_PASSWORD=change-me-demo        # [SECRET]
DEMO_POSTGRES_DSN=postgresql+asyncpg://complianceloop_demo:change-me-demo@localhost:5433/complianceloop_demo

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me                     # [SECRET]
REDIS_DB=0
REDIS_URL=redis://:change-me@localhost:6379/0
REDIS_SANCTIONS_CACHE_TTL=86400              # 24 hours in seconds
REDIS_RATE_LIMIT_DB=1                        # Separate Redis DB for rate limiting
REDIS_CELERY_BROKER_DB=2                     # Separate Redis DB for Celery broker
REDIS_CELERY_RESULT_DB=3                     # Separate Redis DB for Celery results

# ── MinIO (Object Storage) ───────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin                  # [SECRET] Change in production
MINIO_SECRET_KEY=minioadmin                  # [SECRET] Change in production
MINIO_SECURE=false                           # Set true in production (HTTPS)
MINIO_BUCKET_AUDIT=complianceloop-audit
MINIO_BUCKET_FAISS=complianceloop-faiss-snapshots
MINIO_BUCKET_CIRCULARS=complianceloop-raw-circulars

# ── Cryptographic Keys ───────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SERVER_HMAC_KEY=change-me-generate-32-byte-hex-key    # [SECRET] Audit record signing
PAN_HMAC_KEY=change-me-generate-different-32-byte-key # [SECRET] PAN hashing (MUST differ from SERVER_HMAC_KEY)
AES_KEY=change-me-generate-32-byte-hex-key-for-aes    # [SECRET] AES-256-GCM for payload encryption
# Previous HMAC key (kept during rotation for verifying old records — see scripts/rotate_secrets.sh)
SERVER_HMAC_KEY_PREVIOUS=

# ── LLM Inference ────────────────────────────────────────────────────────────
# Using Ollama locally (default) or Groq free tier
LLM_PROVIDER=ollama                          # ollama | groq | openai
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=mistral:7b                         # Model name for Ollama
LLM_TEMPERATURE=0.0                          # 0.0 for deterministic RAG synthesis
LLM_MAX_TOKENS=1000
LLM_TIMEOUT=30                               # Seconds before LLM call times out
# For Groq free tier (alternative to Ollama):
GROQ_API_KEY=                                # [SECRET] Set if LLM_PROVIDER=groq
GROQ_MODEL=mixtral-8x7b-32768

# ── Embeddings ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu                         # cpu | cuda (CPU for cost-free deployment)
EMBEDDING_BATCH_SIZE=32
FAISS_INDEX_DIR=retrieval/index_data         # Path to index directories on disk
FAISS_INDEX_DIMENSION=384                    # all-MiniLM-L6-v2 output dimension

# ── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://:change-me@localhost:6379/2
CELERY_RESULT_BACKEND=redis://:change-me@localhost:6379/3
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_SOFT_TIME_LIMIT=120              # Seconds before soft timeout
CELERY_TASK_TIME_LIMIT=180                   # Seconds before hard timeout
CELERY_TASK_MAX_RETRIES=3
CELERY_TASK_RETRY_BACKOFF=60                 # Seconds between retries (exponential)

# ── Scraper ───────────────────────────────────────────────────────────────────
SCRAPER_INTERVAL_RBI_HOURS=6                 # How often to scrape RBI NBFC circulars
SCRAPER_INTERVAL_KYC_HOURS=12               # How often to scrape RBI KYC amendments
SCRAPER_INTERVAL_DPDP_HOURS=12             # How often to scrape DPDP portal
SCRAPER_INTERVAL_MCA_HOURS=24              # How often to scrape MCA notifications
SCRAPER_USER_AGENT=ComplianceLoop/1.0 (+https://complianceloop.in/bot)
SCRAPER_DOWNLOAD_TIMEOUT=30
SCRAPER_CONCURRENT_REQUESTS=4
# Watchlist update intervals (seconds)
WATCHLIST_UPDATE_INTERVAL_UN=21600           # 6 hours
WATCHLIST_UPDATE_INTERVAL_OFAC=21600         # 6 hours
WATCHLIST_UPDATE_INTERVAL_MHA=86400          # 24 hours

# ── Retro-Evaluation ─────────────────────────────────────────────────────────
RETRO_EVAL_RATE_PER_MIN=50                   # Max re-evals per minute (throttle)
RETRO_EVAL_BATCH_SIZE=100                    # Applications per Celery task batch
RETRO_EVAL_QUEUE_MAX_DEPTH=50000             # Alert threshold for queue depth

# ── Calibration ──────────────────────────────────────────────────────────────
CALIBRATION_RUN_HOUR=2                       # Hour of day (UTC) to run calibration (2 AM)
CALIBRATION_LOOKBACK_DAYS=30                 # Days of reviewer feedback to consider
CALIBRATION_MIN_SAMPLE_SIZE=20              # Min samples per band before adjusting
CALIBRATION_MAX_ADJUSTMENT=0.05             # Max threshold shift per cycle
CALIBRATION_APPROVE_THRESHOLD_DEFAULT=0.82
CALIBRATION_REVIEW_THRESHOLD_DEFAULT=0.60

# ── DPDP Compliance ──────────────────────────────────────────────────────────
DPDP_CONSENT_VALIDITY_HOURS=24              # How long a consent token is valid
DPDP_DEFAULT_RETENTION_DAYS=90             # Default PII retention after decision
DPDP_AUDIT_RETENTION_YEARS=7               # Audit hash/HMAC retained for 7 years
DPDP_BOARD_NOTIFICATION_EMAIL=             # Email for breach notifications (fill in)

# ── Notifications ─────────────────────────────────────────────────────────────
SENDGRID_API_KEY=                           # [SECRET] SendGrid free tier
NOTIFICATION_FROM_EMAIL=noreply@complianceloop.in
NOTIFICATION_FROM_NAME=ComplianceLoop Compliance
NOTIFICATION_RETRY_MAX=3
NOTIFICATION_RETRY_DELAY=60                 # Seconds between retries

# ── HashiCorp Vault ───────────────────────────────────────────────────────────
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=root                            # [SECRET] Dev token — use approle in prod
VAULT_MOUNT_PATH=secret
VAULT_SECRET_PATH=complianceloop
USE_VAULT=false                             # Set true in production to read secrets from Vault

# ── Demo Mode ────────────────────────────────────────────────────────────────
DEMO_MODE=false                             # Enables demo-specific behaviours
DEMO_API_KEY=change-me-demo-api-key         # [SECRET] Protects /demo/guidelines/edit
DEMO_AUTO_PROMOTE_GUIDELINES=true           # Skip human review gate in demo
DEMO_SSE_HEARTBEAT_SECONDS=15              # SSE keepalive interval

# ── API Keys (hashed in DB — these are for initial seeding only) ─────────────
INITIAL_ADMIN_API_KEY=change-me             # [SECRET] First admin key for setup

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=100         # Per IP
RATE_LIMIT_BURST=20                         # Burst allowance

# ── Flower (Celery monitoring UI) ─────────────────────────────────────────────
FLOWER_PORT=5555
FLOWER_BASIC_AUTH=admin:change-me           # [SECRET] Flower UI credentials

# ── Prometheus + Grafana ──────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=change-me            # [SECRET]

# ── Health checks ─────────────────────────────────────────────────────────────
HEALTH_CHECK_FAISS_MAX_AGE_HOURS=48        # Alert if FAISS index older than this
HEALTH_CHECK_DB_TIMEOUT=5                  # Seconds for DB health probe
HEALTH_CHECK_REDIS_TIMEOUT=3
